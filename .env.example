NODE_ENV=development
PORT=8080
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=7d
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
TRANSFER_DAILY_LIMIT=50000
TRANSFER_SINGLE_LIMIT=10000
ALLOWED_ORIGINS=https://localhost:3000
API_KEY_HEADER=x-api-key
EXTERNAL_API_KEY=replace-with-random-client-key
