NODE_ENV=development
PORT=8080
JWT_ACCESS_SECRET=replace-with-long-random-access-secret-min-24-chars
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret-min-24-chars
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=7d
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
TRANSFER_DAILY_LIMIT=50000
TRANSFER_SINGLE_LIMIT=10000
FRAUD_LARGE_AMOUNT_THRESHOLD=5000
FRAUD_VELOCITY_MAX_PER_HOUR=5
ALLOWED_ORIGINS=http://localhost:3000
API_KEY_HEADER=x-api-key
EXTERNAL_API_KEY=replace-with-random-client-key-min-16-chars
REFRESH_COOKIE_NAME=fintrust_refresh
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_TRANSFER_MAX=30
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=10
TRUST_PROXY_HOPS=0
ENABLE_OPENAPI_DOCS=false
# Optional 64 hex chars (32 bytes) for AES-256-GCM field encryption; omit in dev to derive from JWT_REFRESH_SECRET
#FIELD_ENCRYPTION_KEY=
